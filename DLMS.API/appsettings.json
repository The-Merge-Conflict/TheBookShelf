{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=DLMS;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "FileStorage": {
    "BasePath": "wwwroot/uploads",
    "ThumbnailPath": "wwwroot/uploads/thumbnails",
    "AllowedExtensions": [
      ".jpg",
      ".jpeg",
      ".png",
      ".gif",
      ".webp",
      ".pdf",
      ".mp4",
      ".mp3"
    ],
    "MaxFileSizeBytes": 104857600
  },
  "Seeding": {
    "AdminEmail": "admin@dlms.local",
    "DefaultRoles": ["Admin", "Editor", "Viewer"]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/dlms-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "Jwt": {
    "Issuer": "DLMS-API",
    "Audience": "DLMS-Client",
    "ExpireMinutes": 60
  },
  "AllowedHosts": "*"
}
